@* Used by edit pages when the requested entity no longer exists (distinct from the global 404 route). *@
<div class="text-center py-5">
    <i class="bi bi-search fs-1 text-muted d-block mb-3"></i>
    <h1 class="h4 fw-bold mb-2">@Title</h1>
    <p class="text-muted mb-4">@Message</p>
    <a href="@BackHref" class="btn btn-outline-primary px-4">@BackLabel</a>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Not found";
    [Parameter, EditorRequired] public string Message { get; set; } = "";
    [Parameter] public string BackHref { get; set; } = "/";
    [Parameter] public string BackLabel { get; set; } = "Back";
}
