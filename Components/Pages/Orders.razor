@page "/orders"
@layout PublicLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Mvc
@using Netrom_Eco_Meal.Constants
@using Netrom_Eco_Meal.Controllers
@using Netrom_Eco_Meal.Entities
@using Netrom_Eco_Meal.Services
@rendermode InteractiveServer
@implements IDisposable
@inject OrderController OrderController
@inject ClientTimeZoneService ClientTimeZoneService
@attribute [Authorize(Roles = AppRoles.Customer)]

<PageTitle>Your orders — Eco Meal</PageTitle>

<section class="orders-hero">
    <div class="orders-hero-inner">
        <span class="orders-hero-eyebrow"><i class="bi bi-receipt"></i> Pickup history</span>
        <h1 class="orders-hero-title">Your orders</h1>
        <p class="orders-hero-sub">Every rescue you've claimed. Show the ticket number to the kitchen at pickup.</p>

        <div class="orders-stats">
            <div class="orders-stat">
                <span class="orders-stat-value">@(_orders is null ? "—" : _orders.Count.ToString())</span>
                <span class="orders-stat-label">orders placed</span>
            </div>
            <div class="orders-stat">
                <span class="orders-stat-value">@(_orders is null ? "—" : _orders.Where(o => o.Status.Name == OrderStatuses.Completed).Sum(o => o.OrderPackages.Sum(op => op.Quantity)).ToString())</span>
                <span class="orders-stat-label">portions rescued</span>
            </div>
            <div class="orders-stat">
                <span class="orders-stat-value">@(_orders is null ? "—" : _orders.Where(o => o.Status.Name == OrderStatuses.Completed).Select(o => o.BusinessId).Distinct().Count().ToString())</span>
                <span class="orders-stat-label">kitchens visited</span>
            </div>
        </div>
    </div>
</section>

<section class="orders-list-section">
    @if (_actionError is not null)
    {
        <div class="alert alert-danger" role="alert">@_actionError</div>
    }

    @if (_orders is not null && _orders.Count > 0)
    {
        <div class="orders-chip-row">
            <button type="button" class="orders-chip @(_statusFilter == "" ? "orders-chip-active" : "")" @onclick="() => FilterChangedAsync(null)">
                All
            </button>
            @foreach (var status in StatusOrder)
            {
                <button type="button" class="orders-chip @(_statusFilter == status ? "orders-chip-active" : "")"
                        @onclick="() => FilterChangedAsync(status)">
                    @status
                </button>
            }
        </div>
    }

    @if (_orders is null || _paged is null)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (_orders.Count == 0)
    {
        <div class="orders-empty">
            <i class="bi bi-basket2"></i>
            <p class="mb-1">No orders yet.</p>
            <span class="text-muted small d-block mb-3">Rescued food from a kitchen near you shows up here.</span>
            <a href="/" class="btn btn-primary px-4">Browse packages</a>
        </div>
    }
    else if (_paged.Items.Count == 0)
    {
        <div class="orders-empty">
            <i class="bi bi-filter-circle"></i>
            <p class="mb-0">No orders match this status.</p>
        </div>
    }
    else
    {
        <div class="orders-stack">
            @foreach (var order in _paged.Items)
            {
                <article class="order-ticket order-ticket-clickable" role="button" tabindex="0"
                         @onclick="() => _selectedOrder = order" @onkeydown="e => OnTicketKeyDown(e, order)">
                    <div class="order-ticket-main">
                        <div class="order-ticket-top">
                            <div class="order-ticket-kitchen">
                                <div class="order-ticket-business"><i class="bi bi-shop"></i>@order.Business.Name</div>
                                <div class="order-ticket-address"><i class="bi bi-geo-alt"></i>@order.Business.Address</div>
                            </div>
                            <span class="order-status-badge order-status-@order.Status.Name.ToLowerInvariant()">@order.Status.Name</span>
                        </div>

                        <div class="order-ticket-items">
                            @foreach (var line in order.OrderPackages)
                            {
                                <div class="order-ticket-line">
                                    <span class="order-ticket-line-qty">@(line.Quantity)&times;</span>
                                    <span class="order-ticket-line-name">@line.Package.Name</span>
                                    <span class="order-ticket-line-price">@((line.Quantity * line.Package.Price).ToString("C"))</span>
                                </div>
                            }
                        </div>

                        <div class="order-ticket-footer">
                            <div class="order-ticket-pickup">
                                <i class="bi bi-clock"></i>Pickup @PickupWindow(order)
                            </div>
                            <div class="order-ticket-total">
                                <span>Total</span>
                                <span class="order-ticket-total-value">@order.OrderPackages.Sum(op => op.Quantity * op.Package.Price).ToString("C")</span>
                            </div>
                        </div>

                        @* Mirrors OrderService's allowed transitions — a customer can back out any time before pickup is confirmed complete. *@
                        @if (order.Status.Name is OrderStatuses.Pending or OrderStatuses.Confirmed)
                        {
                            <div class="order-ticket-actions">
                                @if (order.Status.Name == OrderStatuses.Confirmed)
                                {
                                    <a href="/orders/pickup/@order.Id" class="order-action-btn order-action-qr" @onclick:stopPropagation="true">
                                        <i class="bi bi-qr-code"></i> Show QR code
                                    </a>
                                }
                                <button type="button" class="order-action-btn order-action-cancel" @onclick="() => RequestCancel(order)" @onclick:stopPropagation="true">
                                    Cancel order
                                </button>
                            </div>
                        }
                    </div>

                    <div class="order-ticket-seam"></div>

                    <div class="order-ticket-stub">
                        <span class="order-ticket-stub-label">Order</span>
                        <span class="order-ticket-stub-number">#@order.OrderNumber.ToString("000")</span>
                        <span class="order-ticket-stub-hint">Show at pickup</span>
                    </div>
                </article>
            }
        </div>
        <Pagination CurrentPage="_paged.PageIndex" TotalPages="_paged.TotalPages" OnPageChange="PageChangedAsync" />
    }
</section>

<ConfirmDialog IsOpen="@(_pendingCancel is not null)"
               Title="Cancel order?"
               Message="@(_pendingCancel is null ? "" : $"Order #{_pendingCancel.OrderNumber:000} at {_pendingCancel.Business.Name} will be cancelled. This can't be undone.")"
               ConfirmLabel="Cancel order"
               Busy="@_cancelling"
               OnConfirm="ConfirmCancelAsync"
               OnCancel="() => _pendingCancel = null"/>

<OrderDetailModal Order="_selectedOrder" PickupLabel="@(_selectedOrder is null ? "" : PickupWindow(_selectedOrder))" OnClose="() => _selectedOrder = null"/>

@code {
    // Lifecycle order for the filter chips, not alphabetical or appearance order.
    private static readonly string[] StatusOrder = [OrderStatuses.Pending, OrderStatuses.Confirmed, OrderStatuses.Completed, OrderStatuses.Cancelled];

    // Loaded once, unfiltered, purely for the lifetime stats in the hero — the rendered
    // ticket list itself comes from the paginated/filtered server query below.
    private List<Order>? _orders;
    private PaginatedList<Order>? _paged;
    private string _statusFilter = "";
    private int _pageIndex = 1;
    private const int PageSize = 10;
    // Guards every reload trigger (status chips, paging) so overlapping ones cancel
    // each other instead of using the shared DbContext concurrently.
    private readonly Debouncer _reloadGate = new();

    private Order? _pendingCancel;
    private bool _cancelling;
    private string? _actionError;
    private Order? _selectedOrder;

    protected override async Task OnInitializedAsync()
    {
        _orders = (await OrderController.GetMyOrdersAsync()).Value ?? [];
        await LoadPageAsync();

        ClientTimeZoneService.OnChange += HandleTimeZoneChanged;
    }

    private async Task LoadPageAsync()
    {
        _paged = (await OrderController.GetMyOrdersPagedAsync(_pageIndex, PageSize, _statusFilter == "" ? null : _statusFilter)).Value;
    }

    private Task ReloadAsync() => _reloadGate.DebounceAsync(LoadPageAsync);

    private void RequestCancel(Order order) => _pendingCancel = order;

    private void OnTicketKeyDown(KeyboardEventArgs e, Order order)
    {
        if (e.Key is "Enter" or " ")
            _selectedOrder = order;
    }

    private async Task ConfirmCancelAsync()
    {
        if (_pendingCancel is null)
            return;

        _cancelling = true;
        _actionError = null;

        var result = await OrderController.CancelMyOrderAsync(_pendingCancel.Id);
        if (result.Result is ConflictObjectResult conflict)
        {
            _actionError = conflict.Value as string ?? "That order couldn't be cancelled.";
        }
        else
        {
            // The cancelled order affects both the lifetime stats (unfiltered _orders) and
            // the ticket list currently on screen, so refresh both.
            _orders = (await OrderController.GetMyOrdersAsync()).Value ?? [];
            await ReloadAsync();
        }

        _cancelling = false;
        _pendingCancel = null;
    }

    private Task FilterChangedAsync(string? status)
    {
        _statusFilter = status ?? "";
        _pageIndex = 1;
        return ReloadAsync();
    }

    private Task PageChangedAsync(int page)
    {
        _pageIndex = page;
        return ReloadAsync();
    }

    private void HandleTimeZoneChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ClientTimeZoneService.OnChange -= HandleTimeZoneChanged;
    }

    private string PickupWindow(Order order)
    {
        if (order.OrderPackages.Count == 0)
            return "time to be confirmed";

        // An order can span packages with different windows — show the widest span that covers them all.
        var start = ClientTimeZoneService.ToLocal(order.OrderPackages.Min(op => op.Package.PickupStart));
        var end = ClientTimeZoneService.ToLocal(order.OrderPackages.Max(op => op.Package.PickupEnd));

        return start.Date == end.Date
            ? $"{start:MMM d} · {start:HH:mm}–{end:HH:mm}"
            : $"{start:MMM d, HH:mm} – {end:MMM d, HH:mm}";
    }
}
