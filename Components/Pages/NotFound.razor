@* Routes.razor's NotFoundPage, and the target of UseStatusCodePagesWithReExecute for 404s. *@
@page "/not-found"
@layout PublicLayout

<PageTitle>Page not found — Eco Meal</PageTitle>

<div class="text-center py-5 mx-auto" style="max-width: 420px; margin-top: 4rem;">
    <i class="bi bi-signpost-2 fs-1 text-muted d-block mb-3"></i>
    <h1 class="h4 fw-bold mb-2">Page not found</h1>
    <p class="text-muted mb-4">The page you're looking for doesn't exist or may have moved.</p>
    <a href="/" class="btn btn-outline-primary px-4">Back to home</a>
</div>