@page "/orders/manage"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Mvc
@using Netrom_Eco_Meal.Constants
@using Netrom_Eco_Meal.Controllers
@using Netrom_Eco_Meal.Entities
@using Netrom_Eco_Meal.Services
@using Netrom_Eco_Meal.Services.Interfaces
@rendermode InteractiveServer
@implements IDisposable
@inject OrderController OrderController
@inject IBusinessService BusinessService
@inject AuthenticationStateProvider AuthStateProvider
@inject ClientTimeZoneService ClientTimeZoneService
@attribute [Authorize(Roles = $"{AppRoles.Admin},{AppRoles.BusinessManager}")]

<PageTitle>Manage Orders — Eco Meal</PageTitle>

@if (_forbidden)
{
    <ForbiddenPanel Message="@_forbiddenReason" BackHref="/dashboard" BackLabel="Back to dashboard"/>
    return;
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">Manage Orders</h1>
        <p class="text-muted small mb-0">@(_isAdmin ? "Review orders across every business" : "Confirm, complete, or cancel orders placed at your business")</p>
    </div>
    @if (!_isAdmin)
    {
        <a href="/orders/scan" class="btn btn-primary px-4">
            <i class="bi bi-qr-code-scan me-1"></i> Scan pickup
        </a>
    }
</div>

@if (_actionError is not null)
{
    <div class="alert alert-danger" role="alert">@_actionError</div>
}

@if (_paged is not null)
{
    <div class="d-flex gap-3 mb-3 flex-wrap">
        <div class="input-group" style="max-width: 320px;">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" class="form-control border-start-0 ps-0" placeholder="Search order # or customer…"
                   @bind="_search" @bind:event="oninput" @bind:after="OnSearchInputAsync" />
        </div>
        @if (_isAdmin)
        {
            <select class="form-select" style="max-width: 220px;" @bind="_businessFilter" @bind:after="FilterChangedAsync">
                <option value="">All businesses</option>
                @foreach (var b in _allBusinesses)
                {
                    <option value="@b.Id">@b.Name</option>
                }
            </select>
        }
        <select class="form-select" style="max-width: 180px;" @bind="_statusFilter" @bind:after="FilterChangedAsync">
            <option value="">All statuses</option>
            @foreach (var s in StatusOrder)
            {
                <option value="@s">@s</option>
            }
        </select>
        @if (!string.IsNullOrEmpty(_search) || _businessFilter != "" || _statusFilter != "")
        {
            <button class="btn btn-outline-secondary" @onclick="ClearFiltersAsync">
                <i class="bi bi-x-lg me-1"></i> Clear
            </button>
        }
        <span class="align-self-center text-muted small ms-auto">@_paged.TotalCount result@(_paged.TotalCount == 1 ? "" : "s")</span>
    </div>
}

<div class="card border-0 shadow-sm">
    @if (_paged is null)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (_paged.Items.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-receipt fs-1 text-muted d-block mb-3"></i>
            <p class="text-muted mb-0">@(_paged.TotalCount == 0 && string.IsNullOrEmpty(_search) && _businessFilter == "" && _statusFilter == "" ? "No orders have been placed yet." : "No orders match your filters.")</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead>
                <tr class="border-bottom">
                    <th class="px-4 py-3 text-uppercase text-muted small fw-semibold">Order</th>
                    @if (_isAdmin)
                    {
                        <th class="py-3 text-uppercase text-muted small fw-semibold">Business</th>
                    }
                    <th class="py-3 text-uppercase text-muted small fw-semibold">Customer</th>
                    <th class="py-3 text-uppercase text-muted small fw-semibold">Items</th>
                    <th class="py-3 text-uppercase text-muted small fw-semibold">Total</th>
                    <th class="py-3 text-uppercase text-muted small fw-semibold">Pickup</th>
                    <th class="py-3 text-uppercase text-muted small fw-semibold">Status</th>
                    @* Admins get cross-business visibility but act through the owning manager, not from here. *@
                    @if (!_isAdmin)
                    {
                        <th class="py-3 text-uppercase text-muted small fw-semibold">Actions</th>
                    }
                </tr>
                </thead>
                <tbody>
                @foreach (var order in _paged.Items)
                {
                    <tr class="order-row-clickable" @onclick="() => _selectedOrder = order">
                        <td class="px-4 fw-semibold">#@order.OrderNumber.ToString("000")</td>
                        @if (_isAdmin)
                        {
                            <td>@order.Business.Name</td>
                        }
                        <td>@order.User.Name</td>
                        <td>
                            @foreach (var line in order.OrderPackages)
                            {
                                <div class="small text-nowrap">@(line.Quantity)&times; @line.Package.Name</div>
                            }
                        </td>
                        <td class="fw-semibold">@order.OrderPackages.Sum(op => op.Quantity * op.Package.Price).ToString("C")</td>
                        <td class="text-muted small">@PickupWindow(order)</td>
                        <td>
                            <span class="order-status-badge order-status-@order.Status.Name.ToLowerInvariant()">@order.Status.Name</span>
                        </td>
                        @if (!_isAdmin)
                        {
                            <td>
                                @if (_busyOrderId == order.Id)
                                {
                                    <div class="spinner-border spinner-border-sm text-muted" role="status">
                                        <span class="visually-hidden">Updating...</span>
                                    </div>
                                }
                                @* Allowed transitions mirror OrderService.UpdateStatusAsync — keep them in sync. *@
                                else if (order.Status.Name == OrderStatuses.Pending)
                                {
                                    <div class="order-action-group" @onclick:stopPropagation="true">
                                        <button type="button" class="order-action-btn order-action-confirm" @onclick="() => ChangeStatusAsync(order, OrderStatuses.Confirmed)">
                                            <i class="bi bi-check-lg"></i> Confirm
                                        </button>
                                        <button type="button" class="order-action-btn order-action-cancel" @onclick="() => ChangeStatusAsync(order, OrderStatuses.Cancelled)">
                                            Cancel
                                        </button>
                                    </div>
                                }
                                else if (order.Status.Name == OrderStatuses.Confirmed)
                                {
                                    <div class="order-action-group" @onclick:stopPropagation="true">
                                        <button type="button" class="order-action-btn order-action-complete" @onclick="() => ChangeStatusAsync(order, OrderStatuses.Completed)">
                                            <i class="bi bi-check2-all"></i> Complete
                                        </button>
                                        <button type="button" class="order-action-btn order-action-cancel" @onclick="() => ChangeStatusAsync(order, OrderStatuses.Cancelled)">
                                            Cancel
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <span class="order-action-empty">—</span>
                                }
                            </td>
                        }
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <Pagination CurrentPage="_paged.PageIndex" TotalPages="_paged.TotalPages" OnPageChange="PageChangedAsync" />
    }
</div>

<OrderDetailModal Order="_selectedOrder" PickupLabel="@(_selectedOrder is null ? "" : PickupWindow(_selectedOrder))" OnClose="() => _selectedOrder = null"/>

@code {
    private static readonly string[] StatusOrder = [OrderStatuses.Pending, OrderStatuses.Confirmed, OrderStatuses.Completed, OrderStatuses.Cancelled];

    private PaginatedList<Order>? _paged;
    private List<Business> _allBusinesses = [];
    private string _search = "";
    private string _businessFilter = "";
    private string _statusFilter = "";
    private bool _isAdmin;
    private bool _forbidden;
    private string _forbiddenReason = "";
    private string? _actionError;
    private Guid? _busyOrderId;
    private Order? _selectedOrder;
    private int _pageIndex = 1;
    private const int PageSize = 10;
    // Guards every reload trigger (search, filters, paging) so overlapping ones cancel
    // each other instead of using the shared DbContext concurrently.
    private readonly Debouncer _reloadGate = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAdmin = authState.User.IsInRole(AppRoles.Admin);

        if (_isAdmin)
            _allBusinesses = (await BusinessService.GetAllAsync()).OrderBy(b => b.Name).ToList();

        await LoadPageAsync();

        if (_forbidden)
            return;

        ClientTimeZoneService.OnChange += HandleTimeZoneChanged;
    }

    private async Task LoadPageAsync()
    {
        Guid? businessId = Guid.TryParse(_businessFilter, out var bId) ? bId : null;
        var result = await OrderController.GetOrdersForManagementPagedAsync(_pageIndex, PageSize, _search, businessId, _statusFilter == "" ? null : _statusFilter);
        if (result.Result is UnauthorizedResult)
        {
            _forbidden = true;
            _forbiddenReason = "You don't manage a business yet, so there are no orders to show.";
            return;
        }

        _paged = result.Value;
    }

    private void HandleTimeZoneChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ClientTimeZoneService.OnChange -= HandleTimeZoneChanged;
    }

    private Task ReloadAsync(int delayMs = 0) => _reloadGate.DebounceAsync(LoadPageAsync, delayMs);

    private Task OnSearchInputAsync()
    {
        _pageIndex = 1;
        return ReloadAsync(300);
    }

    private Task FilterChangedAsync()
    {
        _pageIndex = 1;
        return ReloadAsync();
    }

    private Task PageChangedAsync(int page)
    {
        _pageIndex = page;
        return ReloadAsync();
    }

    private Task ClearFiltersAsync()
    {
        _search = "";
        _businessFilter = "";
        _statusFilter = "";
        return FilterChangedAsync();
    }

    private async Task ChangeStatusAsync(Order order, string statusName)
    {
        _actionError = null;
        _busyOrderId = order.Id;

        var result = await OrderController.UpdateOrderStatusAsync(order.Id, statusName);
        if (result.Result is ConflictObjectResult conflict)
        {
            _actionError = conflict.Value as string ?? "That status change couldn't be completed.";
        }
        else if (result.Value is not null && _paged is not null)
        {
            var index = _paged.Items.FindIndex(o => o.Id == result.Value.Id);
            if (index >= 0)
                _paged.Items[index] = result.Value;
        }

        _busyOrderId = null;
    }

    private string PickupWindow(Order order)
    {
        if (order.OrderPackages.Count == 0)
            return "—";

        // An order can span packages with different windows — show the widest span that covers them all.
        var start = ClientTimeZoneService.ToLocal(order.OrderPackages.Min(op => op.Package.PickupStart));
        var end = ClientTimeZoneService.ToLocal(order.OrderPackages.Max(op => op.Package.PickupEnd));

        return start.Date == end.Date
            ? $"{start:MMM d} · {start:HH:mm}–{end:HH:mm}"
            : $"{start:MMM d, HH:mm} – {end:MMM d, HH:mm}";
    }
}
