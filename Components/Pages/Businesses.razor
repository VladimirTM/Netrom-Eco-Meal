@page "/businesses"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Mvc
@using Netrom_Eco_Meal.Constants
@using Netrom_Eco_Meal.Controllers
@using Netrom_Eco_Meal.Entities
@using Netrom_Eco_Meal.Services.Interfaces
@rendermode InteractiveServer
@inject BusinessController BusinessController
@inject UserController UserController
@inject IBusinessTypeService BusinessTypeService
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize(Roles = $"{AppRoles.Admin},{AppRoles.BusinessManager}")]

<PageTitle>Businesses — Eco Meal</PageTitle>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">Businesses</h1>
        <p class="text-muted small mb-0">Manage all registered food businesses</p>
    </div>
    @if (_isAdmin)
    {
        <a href="/businesses/create" class="btn btn-primary px-4">
            <i class="bi bi-plus-lg me-1"></i> Add Business
        </a>
    }
</div>

@if (_assignError is not null)
{
    <div class="alert alert-danger" role="alert">@_assignError</div>
}

@if (_paged is not null && businessTypes is not null)
{
    <div class="d-flex gap-3 mb-3 flex-wrap">
        <div class="input-group" style="max-width: 320px;">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" class="form-control border-start-0 ps-0" placeholder="Search name, description, address…"
                   @bind="_search" @bind:event="oninput" @bind:after="OnSearchInputAsync" />
        </div>
        <select class="form-select" style="max-width: 200px;" @bind="_typeFilter" @bind:after="FilterChangedAsync">
            <option value="">All types</option>
            @foreach (var t in businessTypes)
            {
                <option value="@t.Id">@t.Name</option>
            }
        </select>
        @if (!string.IsNullOrEmpty(_search) || _typeFilter != "")
        {
            <button class="btn btn-outline-secondary" @onclick="ClearFiltersAsync">
                <i class="bi bi-x-lg me-1"></i> Clear
            </button>
        }
        <span class="align-self-center text-muted small ms-auto">@_paged.TotalCount result@(_paged.TotalCount == 1 ? "" : "s")</span>
    </div>
}

<div class="card border-0 shadow-sm">
    @if (_paged is null)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (_paged.Items.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-building fs-1 text-muted d-block mb-3"></i>
            <p class="text-muted mb-3">@((businesses?.Count ?? 0) == 0 ? "No businesses registered yet." : "No businesses match your filters.")</p>
            @if ((businesses?.Count ?? 0) == 0 && _isAdmin)
            {
                <a href="/businesses/create" class="btn btn-outline-primary">Create your first business</a>
            }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead>
                <tr class="border-bottom">
                    <th class="px-4 py-3 text-uppercase text-muted small fw-semibold">Name</th>
                    <th class="py-3 text-uppercase text-muted small fw-semibold">Description</th>
                    <th class="py-3 text-uppercase text-muted small fw-semibold">Address</th>
                    <th class="py-3 text-uppercase text-muted small fw-semibold">Type</th>
                    @if (_isAdmin)
                    {
                        <th class="py-3 text-uppercase text-muted small fw-semibold">Manager</th>
                    }
                    @if (_isAdmin || _isBusinessManager)
                    {
                        <th class="py-3 text-uppercase text-muted small fw-semibold">Actions</th>
                    }
                </tr>
                </thead>
                <tbody>
                @foreach (var business in _paged.Items)
                {
                    var canEdit = _isAdmin || (_isBusinessManager && business.Id == _myBusinessId);
                    <tr>
                        <td class="px-4 fw-semibold">@business.Name</td>
                        <td class="text-muted">@business.Description</td>
                        <td>@business.Address</td>
                        <td>
                            <span class="badge rounded-pill px-3 py-2 business-type-badge">
                                @business.BusinessType.Name
                            </span>
                        </td>
                        @if (_isAdmin)
                        {
                            <td class="position-relative">
                                <AnchoredDropdown TriggerClass="@($"role-badge {(business.Manager is null ? "role-badge-unassigned" : "role-badge-businessmanager")}")"
                                                  IsOpen="@(_openManagerDropdownBusinessId == business.Id)"
                                                  OnToggle="@(() => ToggleManagerDropdown(business.Id))"
                                                  OnClose="CloseManagerDropdown">
                                    <Trigger>
                                        @(business.Manager?.Name ?? "Unassigned")
                                        <i class="bi bi-chevron-down" style="font-size:0.65rem;"></i>
                                    </Trigger>
                                    <Content>
                                        <button type="button" class="role-option" @onclick="() => AssignManagerAsync(business, null)">
                                            <span class="role-option-dot" style="background-color:#6b7280"></span>
                                            Unassigned
                                            @if (business.ManagerId is null)
                                            {
                                                <i class="bi bi-check-lg ms-auto text-muted"></i>
                                            }
                                        </button>
                                        @* A manager can only run one business — flag if picking them would displace another. *@
                                        @foreach (var manager in _businessManagers)
                                        {
                                            var elsewhere = businesses!.FirstOrDefault(b => b.ManagerId == manager.Id && b.Id != business.Id);
                                            <button type="button" class="role-option" @onclick="() => AssignManagerAsync(business, manager.Id)">
                                                <span class="role-option-dot" style="background-color:#2563eb"></span>
                                                <span>
                                                    @manager.Name
                                                    @if (elsewhere is not null)
                                                    {
                                                        <span class="text-muted fw-normal d-block" style="font-size:0.7rem;">currently: @elsewhere.Name</span>
                                                    }
                                                </span>
                                                @if (business.ManagerId == manager.Id)
                                                {
                                                    <i class="bi bi-check-lg ms-auto text-muted"></i>
                                                }
                                            </button>
                                        }
                                    </Content>
                                </AnchoredDropdown>
                            </td>
                        }
                        @if (_isAdmin || _isBusinessManager)
                        {
                            <td>
                                <div class="d-flex gap-2">
                                    @if (canEdit)
                                    {
                                        <a href="/businesses/edit/@business.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    }
                                    @if (_isAdmin)
                                    {
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RequestDelete(business)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        }
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <Pagination CurrentPage="_paged.PageIndex" TotalPages="_paged.TotalPages" OnPageChange="PageChangedAsync" />
    }
</div>

<ConfirmDialog IsOpen="@(_pendingDelete is not null)"
               Title="Delete business?"
               Message="@(_pendingDelete is null ? "" : $"\"{_pendingDelete.Name}\", every package it lists, and its full order history will be permanently removed. This can't be undone.")"
               ConfirmLabel="Delete business"
               Busy="@_deleting"
               OnConfirm="ConfirmDeleteAsync"
               OnCancel="() => _pendingDelete = null"/>

@code {
    // Full, unfiltered list — kept only for cross-page checks (my business, manager assigned
    // elsewhere) that a single paginated page can't answer on its own.
    private List<Business>? businesses;
    private PaginatedList<Business>? _paged;
    private List<BusinessType>? businessTypes;
    private List<Services.Interfaces.UserWithRole> _businessManagers = [];
    private string _search = "";
    private string _typeFilter = "";
    private string? _currentUserId;
    private bool _isAdmin;
    private bool _isBusinessManager;
    private Guid? _myBusinessId;
    private Guid? _openManagerDropdownBusinessId;
    private string? _assignError;
    private Business? _pendingDelete;
    private bool _deleting;
    private int _pageIndex = 1;
    private const int PageSize = 10;
    // Guards every reload trigger (search, filters, paging, post-mutation refresh) so
    // overlapping ones cancel each other instead of using the shared DbContext concurrently.
    private readonly Debouncer _reloadGate = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        _isAdmin = authState.User.IsInRole(AppRoles.Admin);
        _isBusinessManager = authState.User.IsInRole(AppRoles.BusinessManager);

        businesses    = (await BusinessController.GetAllAsync()).Value;
        businessTypes = await BusinessTypeService.GetAllAsync();

        if (_isBusinessManager && _currentUserId is not null)
            _myBusinessId = businesses?.FirstOrDefault(b => b.ManagerId == _currentUserId)?.Id;

        if (_isAdmin)
            _businessManagers = (await UserController.GetByRoleAsync(AppRoles.BusinessManager)).Value ?? [];

        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        Guid? typeId = Guid.TryParse(_typeFilter, out var id) ? id : null;
        var managerId = _isBusinessManager ? _currentUserId : null;
        _paged = (await BusinessController.GetPagedAsync(_pageIndex, PageSize, _search, typeId, managerId)).Value;

        // A mutation (e.g. deleting the last item on the last page) can shrink TotalPages below
        // the page we're currently viewing — re-fetch the now-last valid page instead of showing empty.
        if (_paged is not null && _paged.Items.Count == 0 && _pageIndex > _paged.TotalPages)
        {
            _pageIndex = _paged.TotalPages;
            _paged = (await BusinessController.GetPagedAsync(_pageIndex, PageSize, _search, typeId, managerId)).Value;
        }
    }

    private Task ReloadAsync(int delayMs = 0) => _reloadGate.DebounceAsync(LoadPageAsync, delayMs);

    private Task OnSearchInputAsync()
    {
        _pageIndex = 1;
        return ReloadAsync(300);
    }

    private Task FilterChangedAsync()
    {
        _pageIndex = 1;
        return ReloadAsync();
    }

    private Task PageChangedAsync(int page)
    {
        _pageIndex = page;
        return ReloadAsync();
    }

    private Task ClearFiltersAsync()
    {
        _search     = "";
        _typeFilter = "";
        return FilterChangedAsync();
    }

    private void RequestDelete(Business business)
    {
        if (!_isAdmin)
            return;

        _pendingDelete = business;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_pendingDelete is null)
            return;

        _deleting = true;
        await BusinessController.DeleteAsync(_pendingDelete);
        businesses = (await BusinessController.GetAllAsync()).Value;
        await ReloadAsync();
        _deleting = false;
        _pendingDelete = null;
    }

    private void ToggleManagerDropdown(Guid businessId)
    {
        _openManagerDropdownBusinessId = _openManagerDropdownBusinessId == businessId ? null : businessId;
    }

    private void CloseManagerDropdown()
    {
        _openManagerDropdownBusinessId = null;
    }

    private async Task AssignManagerAsync(Business business, string? managerId)
    {
        _openManagerDropdownBusinessId = null;
        _assignError = null;

        if (!_isAdmin || managerId == business.ManagerId)
            return;

        // A concurrent assignment can beat us to it — refetch and surface the conflict.
        var result = await BusinessController.AssignManagerAsync(business.Id, managerId);
        if (result is ConflictResult)
            _assignError = "That manager was just assigned to another business. Please try again.";

        businesses = (await BusinessController.GetAllAsync()).Value;
        await ReloadAsync();
    }
}