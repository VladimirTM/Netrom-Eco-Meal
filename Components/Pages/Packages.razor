@page "/packages"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Netrom_Eco_Meal.Constants
@using Netrom_Eco_Meal.Controllers
@using Netrom_Eco_Meal.Entities
@using Netrom_Eco_Meal.Services
@using Netrom_Eco_Meal.Services.Interfaces
@rendermode InteractiveServer
@implements IDisposable
@inject PackageController PackageController
@inject IBusinessService BusinessService
@inject IPackageTypeService PackageTypeService
@inject AuthenticationStateProvider AuthStateProvider
@inject ClientTimeZoneService ClientTimeZoneService
@attribute [Authorize(Roles = $"{AppRoles.Admin},{AppRoles.BusinessManager}")]

<PageTitle>Packages — Eco Meal</PageTitle>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">Packages</h1>
        <p class="text-muted small mb-0">Manage all available food packages</p>
    </div>
    @if (_isAdmin || _myBusinessId is not null)
    {
        <a href="/packages/create" class="btn btn-primary px-4">
            <i class="bi bi-plus-lg me-1"></i> Add Package
        </a>
    }
</div>

@if (_paged is not null)
{
    <div class="d-flex gap-3 mb-3 flex-wrap">
        <div class="input-group" style="max-width: 320px;">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" class="form-control border-start-0 ps-0" placeholder="Search name or description…"
                   @bind="_search" @bind:event="oninput" @bind:after="OnSearchInputAsync" />
        </div>
        @if (_isAdmin)
        {
            <select class="form-select" style="max-width: 200px;" @bind="_businessFilter" @bind:after="FilterChangedAsync">
                <option value="">All businesses</option>
                @foreach (var b in _allBusinesses)
                {
                    <option value="@b.Id">@b.Name</option>
                }
            </select>
        }
        <select class="form-select" style="max-width: 180px;" @bind="_typeFilter" @bind:after="FilterChangedAsync">
            <option value="">All types</option>
            @foreach (var t in _packageTypes)
            {
                <option value="@t.Id">@t.Name</option>
            }
        </select>
        @if (!string.IsNullOrEmpty(_search) || _businessFilter != "" || _typeFilter != "")
        {
            <button class="btn btn-outline-secondary" @onclick="ClearFiltersAsync">
                <i class="bi bi-x-lg me-1"></i> Clear
            </button>
        }
        <span class="align-self-center text-muted small ms-auto">@_paged.TotalCount result@(_paged.TotalCount == 1 ? "" : "s")</span>
    </div>
}

<div class="card border-0 shadow-sm">
    @if (_paged is null)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (_paged.Items.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-box-seam fs-1 text-muted d-block mb-3"></i>
            <p class="text-muted mb-3">@(_paged.TotalCount == 0 && string.IsNullOrEmpty(_search) && _businessFilter == "" && _typeFilter == "" ? "No packages available yet." : "No packages match your filters.")</p>
            @if (_paged.TotalCount == 0 && (_isAdmin || _myBusinessId is not null))
            {
                <a href="/packages/create" class="btn btn-outline-primary">Create your first package</a>
            }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead>
                <tr class="border-bottom">
                    <th class="px-4 py-3 text-uppercase text-muted small fw-semibold">Name</th>
                    <th class="py-3 text-uppercase text-muted small fw-semibold">Business</th>
                    <th class="py-3 text-uppercase text-muted small fw-semibold">Type</th>
                    <th class="py-3 text-uppercase text-muted small fw-semibold">Price</th>
                    <th class="py-3 text-uppercase text-muted small fw-semibold">Qty</th>
                    <th class="py-3 text-uppercase text-muted small fw-semibold">Pickup</th>
                    @if (_isAdmin || _isBusinessManager)
                    {
                        <th class="py-3 text-uppercase text-muted small fw-semibold">Actions</th>
                    }
                </tr>
                </thead>
                <tbody>
                @* Managers only see packages belonging to their own business here. *@
                @foreach (var package in _paged.Items)
                {
                    var canManage = _isAdmin || (_isBusinessManager && package.BusinessId == _myBusinessId);
                    <tr>
                        <td class="px-4">
                            <div class="fw-semibold">@package.Name</div>
                            <div class="text-muted small">@package.Description</div>
                        </td>
                        <td>@package.Business.Name</td>
                        <td>
                            <span class="badge rounded-pill px-3 py-2 package-type-badge">
                                @package.PackageType.Name
                            </span>
                        </td>
                        <td class="fw-semibold">@package.Price.ToString("C")</td>
                        <td>@package.Quantity</td>
                        <td class="text-muted small">
                            @PickupLabel(package)
                        </td>
                        @if (_isAdmin || _isBusinessManager)
                        {
                            <td>
                                @if (canManage)
                                {
                                    <div class="d-flex gap-2">
                                        <a href="/packages/edit/@package.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RequestDelete(package)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                }
                            </td>
                        }
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <Pagination CurrentPage="_paged.PageIndex" TotalPages="_paged.TotalPages" OnPageChange="PageChangedAsync" />
    }
</div>

<ConfirmDialog IsOpen="@(_pendingDelete is not null)"
               Title="Delete package?"
               Message="@(_pendingDelete is null ? "" : $"\"{_pendingDelete.Name}\" will be permanently removed and can no longer be ordered. This can't be undone.")"
               ConfirmLabel="Delete package"
               Busy="@_deleting"
               OnConfirm="ConfirmDeleteAsync"
               OnCancel="() => _pendingDelete = null"/>

@code {
    private PaginatedList<Package>? _paged;
    private List<Business> _allBusinesses = [];
    private List<PackageType> _packageTypes = [];
    private string _search = "";
    private string _businessFilter = "";
    private string _typeFilter = "";
    private bool _isAdmin;
    private bool _isBusinessManager;
    private Guid? _myBusinessId;
    private Package? _pendingDelete;
    private bool _deleting;
    private int _pageIndex = 1;
    private const int PageSize = 10;
    // Guards every reload trigger (search, filters, paging, post-mutation refresh) so
    // overlapping ones cancel each other instead of using the shared DbContext concurrently.
    private readonly Debouncer _reloadGate = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        _isAdmin = authState.User.IsInRole(AppRoles.Admin);
        _isBusinessManager = authState.User.IsInRole(AppRoles.BusinessManager);

        if (_isBusinessManager && currentUserId is not null)
            _myBusinessId = (await BusinessService.GetByManagerIdAsync(currentUserId))?.Id;

        _allBusinesses = (await BusinessService.GetAllAsync())?.OrderBy(b => b.Name).ToList() ?? [];
        _packageTypes = (await PackageTypeService.GetAllAsync()).OrderBy(t => t.Name).ToList();

        await LoadPageAsync();

        ClientTimeZoneService.OnChange += HandleTimeZoneChanged;
    }

    private async Task LoadPageAsync()
    {
        // An unassigned manager has no business — fall back to a Guid that can never match
        // rather than leaving the filter null, which would otherwise show every business's packages.
        Guid? businessId = _isBusinessManager ? _myBusinessId ?? Guid.Empty : (Guid.TryParse(_businessFilter, out var bId) ? bId : null);
        Guid? packageTypeId = Guid.TryParse(_typeFilter, out var tId) ? tId : null;
        _paged = (await PackageController.GetPagedAsync(_pageIndex, PageSize, _search, businessId, packageTypeId)).Value;

        // A mutation (e.g. deleting the last item on the last page) can shrink TotalPages below
        // the page we're currently viewing — re-fetch the now-last valid page instead of showing empty.
        if (_paged is not null && _paged.Items.Count == 0 && _pageIndex > _paged.TotalPages)
        {
            _pageIndex = _paged.TotalPages;
            _paged = (await PackageController.GetPagedAsync(_pageIndex, PageSize, _search, businessId, packageTypeId)).Value;
        }
    }

    private Task ReloadAsync(int delayMs = 0) => _reloadGate.DebounceAsync(LoadPageAsync, delayMs);

    private Task OnSearchInputAsync()
    {
        _pageIndex = 1;
        return ReloadAsync(300);
    }

    private Task FilterChangedAsync()
    {
        _pageIndex = 1;
        return ReloadAsync();
    }

    private Task PageChangedAsync(int page)
    {
        _pageIndex = page;
        return ReloadAsync();
    }

    private string PickupLabel(Package package)
    {
        var start = ClientTimeZoneService.ToLocal(package.PickupStart);
        var end = ClientTimeZoneService.ToLocal(package.PickupEnd);
        return $"{start:MMM d, HH:mm} – {end:HH:mm}";
    }

    private void HandleTimeZoneChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ClientTimeZoneService.OnChange -= HandleTimeZoneChanged;
    }

    private Task ClearFiltersAsync()
    {
        _search         = "";
        _businessFilter = "";
        _typeFilter     = "";
        return FilterChangedAsync();
    }

    private void RequestDelete(Package package)
    {
        if (!_isAdmin && package.BusinessId != _myBusinessId)
            return;

        _pendingDelete = package;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_pendingDelete is null)
            return;

        _deleting = true;
        await PackageController.DeleteAsync(_pendingDelete);
        await ReloadAsync();
        _deleting = false;
        _pendingDelete = null;
    }
}