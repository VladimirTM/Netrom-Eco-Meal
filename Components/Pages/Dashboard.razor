@page "/dashboard"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc
@using Microsoft.EntityFrameworkCore
@using Netrom_Eco_Meal.Constants
@using Netrom_Eco_Meal.Controllers
@using Netrom_Eco_Meal.Entities
@using Netrom_Eco_Meal.Services.Interfaces
@rendermode InteractiveServer
@inject BusinessController BusinessController
@inject PackageController PackageController
@inject OrderController OrderController
@inject IBusinessService BusinessService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize(Roles = $"{AppRoles.Admin},{AppRoles.BusinessManager}")]

<PageTitle>Dashboard — Eco Meal</PageTitle>

<div class="mb-4">
    <h1 class="h3 fw-bold mb-1">Dashboard</h1>
    <p class="text-muted small mb-0">Welcome to the Eco Meal Admin Panel</p>
</div>

<div class="row g-3 mb-4">
    @if (_isAdmin)
    {
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 card-accent-green">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3 bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-building fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Businesses</div>
                        @if (_businessCount is null)
                        {
                            <div class="spinner-border spinner-border-sm text-primary mt-1" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        }
                        else
                        {
                            <div class="fw-bold fs-4">@_businessCount</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 card-accent-blue">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3 bg-sky-subtle text-sky">
                    <i class="bi bi-box-seam fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">@(_isAdmin ? "Packages" : "Your Packages")</div>
                    @if (_packageCount is null)
                    {
                        <div class="spinner-border spinner-border-sm text-sky mt-1" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    }
                    else
                    {
                        <div class="fw-bold fs-4">@_packageCount</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 card-accent-amber">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3 bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-cart3 fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Orders</div>
                    @if (_ordersUnavailable)
                    {
                        <div class="fw-bold fs-6 text-muted">Not assigned</div>
                    }
                    else if (_orderCount is null)
                    {
                        <div class="spinner-border spinner-border-sm text-warning mt-1" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    }
                    else
                    {
                        <div class="fw-bold fs-4">@_orderCount</div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (_isAdmin)
    {
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 card-accent-purple">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3 bg-purple-subtle text-purple">
                        <i class="bi bi-people fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Users</div>
                        @if (_userCount is null)
                        {
                            <div class="spinner-border spinner-border-sm text-purple mt-1" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        }
                        else
                        {
                            <div class="fw-bold fs-4">@_userCount</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
        <h6 class="fw-semibold mb-0">Quick Actions</h6>
    </div>
    <div class="card-body px-4 pb-4">
        <div class="row g-2">
            <div class="col-sm-6 col-lg-3">
                <a href="/businesses" class="btn btn-outline-secondary w-100 d-flex align-items-center gap-2">
                    <i class="bi bi-building"></i> All Businesses
                </a>
            </div>
            <AuthorizeView Roles="@AppRoles.Admin" Context="adminContext">
                <Authorized>
                    <div class="col-sm-6 col-lg-3">
                        <a href="/businesses/create" class="btn btn-outline-primary w-100 d-flex align-items-center gap-2">
                            <i class="bi bi-plus-lg"></i> Add Business
                        </a>
                    </div>
                </Authorized>
            </AuthorizeView>
            <div class="col-sm-6 col-lg-3">
                <a href="/packages" class="btn btn-outline-secondary w-100 d-flex align-items-center gap-2">
                    <i class="bi bi-box-seam"></i> All Packages
                </a>
            </div>
            <AuthorizeView Roles="@($"{AppRoles.Admin},{AppRoles.BusinessManager}")" Context="managerContext">
                <Authorized>
                    <div class="col-sm-6 col-lg-3">
                        <a href="/packages/create" class="btn btn-outline-primary w-100 d-flex align-items-center gap-2">
                            <i class="bi bi-plus-lg"></i> Add Package
                        </a>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <a href="/orders/manage" class="btn btn-outline-secondary w-100 d-flex align-items-center gap-2">
                            <i class="bi bi-cart3"></i> Manage Orders
                        </a>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>
</div>

@code {
    private bool _isAdmin;
    private int? _businessCount;
    private int? _packageCount;
    private int? _orderCount;
    private int? _userCount;
    private bool _ordersUnavailable;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAdmin = authState.User.IsInRole(AppRoles.Admin);
        var currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        var allPackages = (await PackageController.GetAllAsync()).Value ?? [];

        // Business managers only see counts scoped to their own business, not platform-wide totals.
        if (_isAdmin)
        {
            _businessCount = (await BusinessController.GetAllAsync()).Value?.Count;
            _packageCount = allPackages.Count;
            _userCount = await UserManager.Users.CountAsync();
        }
        else if (currentUserId is not null)
        {
            var myBusiness = await BusinessService.GetByManagerIdAsync(currentUserId);
            _packageCount = myBusiness is null ? 0 : allPackages.Count(p => p.BusinessId == myBusiness.Id);
        }

        var orders = await OrderController.GetOrdersForManagementAsync();
        if (orders.Result is UnauthorizedResult)
            _ordersUnavailable = true;
        else
            _orderCount = orders.Value?.Count ?? 0;
    }
}