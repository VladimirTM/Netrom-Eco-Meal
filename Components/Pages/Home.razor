@page "/"
@layout PublicLayout
@using Microsoft.AspNetCore.Components.Authorization
@using Netrom_Eco_Meal.Constants
@using Netrom_Eco_Meal.Controllers
@using Netrom_Eco_Meal.Entities
@using Netrom_Eco_Meal.Services
@using Netrom_Eco_Meal.Services.Interfaces
@rendermode InteractiveServer
@implements IDisposable
@inject BusinessController BusinessController
@inject PackageController PackageController
@inject ReviewController ReviewController
@inject IBusinessTypeService BusinessTypeService
@inject CartService CartService
@inject NavigationManager NavigationManager

<PageTitle>Eco Meal — rescue surplus food near you</PageTitle>

<section class="home-hero">
    <div class="home-hero-inner">
        <span class="home-hero-eyebrow"><i class="bi bi-geo-alt-fill"></i> Near you, live now</span>
        <h1 class="home-hero-title">
            Today's surplus,<br/>
            <span class="home-hero-highlight">rescued</span> before it's binned.
        </h1>
        <p class="home-hero-sub">
            Local restaurants, bakeries and cafés list the food they'd otherwise throw out at closing time —
            at a fraction of the price. Pick a kitchen to see what's left and book your pickup.
        </p>

        <div class="home-stats">
            <div class="home-stat">
                <span class="home-stat-value">@(_livePackages is null ? "—" : _livePackages.Count.ToString())</span>
                <span class="home-stat-label">packages live</span>
            </div>
            <div class="home-stat">
                <span class="home-stat-value">@(_livePackages is null ? "—" : _livePackages.Sum(p => CartService.AvailableQuantity(p)).ToString())</span>
                <span class="home-stat-label">portions to save</span>
            </div>
            <div class="home-stat">
                <span class="home-stat-value">@(_livePackages is null ? "—" : _livePackages.Select(p => p.BusinessId).Distinct().Count().ToString())</span>
                <span class="home-stat-label">kitchens on board</span>
            </div>
        </div>
    </div>
</section>

<section class="home-browse">
    @if (_paged is not null)
    {
        <div class="home-filter-bar">
            <div class="input-group home-search">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" class="form-control border-start-0 ps-0" placeholder="Search kitchens…"
                       @bind="_search" @bind:event="oninput" @bind:after="OnSearchInputAsync"/>
            </div>

            <select class="form-select home-business-filter" @bind="_businessTypeFilter" @bind:after="FilterChangedAsync">
                <option value="">All kitchen types</option>
                @foreach (var bt in _businessTypes ?? [])
                {
                    <option value="@bt.Id">@bt.Name</option>
                }
            </select>

            @if (HasActiveFilters)
            {
                <button class="btn btn-outline-secondary btn-sm" @onclick="ClearFiltersAsync">
                    <i class="bi bi-x-lg me-1"></i>Clear
                </button>
            }
        </div>

        <div class="home-results-row">
            <span class="text-muted small">@_paged.TotalCount kitchen@(_paged.TotalCount == 1 ? "" : "s") found</span>
        </div>
    }

    @if (_paged is null)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (_paged.Items.Count == 0)
    {
        <div class="home-empty">
            <i class="bi bi-shop fs-1 text-muted d-block mb-3"></i>
            <p class="text-muted mb-0">@(_paged.TotalCount == 0 && !HasActiveFilters ? "No kitchens have joined yet — check back soon." : "Nothing matches your filters yet.")</p>
        </div>
    }
    else
    {
        <div class="biz-grid">
            @foreach (var business in _paged.Items)
            {
                var live = LivePackagesFor(business.Id);
                var reviews = ReviewsFor(business.Id);
                <button type="button" class="biz-card" @key="business.Id" @onclick="() => OpenBusiness(business.Id)">
                    <div class="biz-card-media" style="@MediaStyle(business.ImageUrl)">
                        @if (live.Count > 0)
                        {
                            <span class="biz-card-live-badge"><span class="biz-card-live-dot"></span>@live.Count live</span>
                        }
                        @if (reviews.Count > 0)
                        {
                            <span class="biz-card-rating-badge">
                                <StarRating Value="@reviews.Average(r => r.Rating)" Size="0.65rem"/>
                                @reviews.Average(r => r.Rating).ToString("0.0")
                            </span>
                        }
                    </div>
                    <div class="biz-card-body">
                        <span class="biz-card-type">@business.BusinessType.Name</span>
                        <h2 class="biz-card-name">@business.Name</h2>
                        <div class="biz-card-address"><i class="bi bi-geo-alt-fill"></i>@business.Address</div>
                        <p class="biz-card-desc">@business.Description</p>
                        <div class="biz-card-footer">
                            @if (live.Count > 0)
                            {
                                <span class="biz-card-from">from @live.Min(p => p.Price).ToString("C")</span>
                            }
                            else
                            {
                                <span class="biz-card-from biz-card-from-muted">Nothing live now</span>
                            }
                            <span class="biz-card-cta">View kitchen <i class="bi bi-arrow-right"></i></span>
                        </div>
                    </div>
                </button>
            }
        </div>

        <div class="home-pagination">
            <Pagination CurrentPage="_paged.PageIndex" TotalPages="_paged.TotalPages" OnPageChange="PageChangedAsync"/>
        </div>
    }
</section>

@code {
    private PaginatedList<Business>? _paged;
    private List<BusinessType>? _businessTypes;
    private List<Package>? _livePackages;
    private Dictionary<Guid, List<Package>> _livePackagesByBusiness = [];
    private Dictionary<Guid, List<Review>> _reviewsByBusiness = [];

    private string _search = "";
    private string _businessTypeFilter = "";
    private int _pageIndex = 1;
    private const int PageSize = 9;
    private readonly Debouncer _reloadGate = new();

    private bool HasActiveFilters => _search != "" || _businessTypeFilter != "";

    protected override async Task OnInitializedAsync()
    {
        _businessTypes = await BusinessTypeService.GetAllAsync();

        var packages = (await PackageController.GetAllAsync()).Value;
        // Only count packages still orderable today — DbSeeder keeps seed data's window fresh.
        _livePackages = packages?.Where(p => p.PickupEnd > DateTime.UtcNow).ToList() ?? [];
        _livePackagesByBusiness = _livePackages.GroupBy(p => p.BusinessId).ToDictionary(g => g.Key, g => g.ToList());

        CartService.OnChange += HandleCartChanged;

        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        Guid? typeId = Guid.TryParse(_businessTypeFilter, out var id) ? id : null;
        _paged = (await BusinessController.GetPagedAsync(_pageIndex, PageSize, _search, typeId)).Value;

        // Only fetch reviews for the businesses actually shown on this page, not the whole table.
        var businessIds = _paged?.Items.Select(b => b.Id).ToList() ?? [];
        var reviews = businessIds.Count == 0 ? [] : (await ReviewController.GetByBusinessesAsync(businessIds)).Value ?? [];
        _reviewsByBusiness = reviews.GroupBy(r => r.BusinessId).ToDictionary(g => g.Key, g => g.ToList());
    }

    private Task ReloadAsync(int delayMs = 0) => _reloadGate.DebounceAsync(LoadPageAsync, delayMs);

    private Task OnSearchInputAsync()
    {
        _pageIndex = 1;
        return ReloadAsync(300);
    }

    private Task FilterChangedAsync()
    {
        _pageIndex = 1;
        return ReloadAsync();
    }

    private Task PageChangedAsync(int page)
    {
        _pageIndex = page;
        return ReloadAsync();
    }

    private Task ClearFiltersAsync()
    {
        _search = "";
        _businessTypeFilter = "";
        return FilterChangedAsync();
    }

    private List<Package> LivePackagesFor(Guid businessId) =>
        _livePackagesByBusiness.GetValueOrDefault(businessId, []);

    private List<Review> ReviewsFor(Guid businessId) =>
        _reviewsByBusiness.GetValueOrDefault(businessId, []);

    private static string MediaStyle(string? imageUrl) => string.IsNullOrWhiteSpace(imageUrl)
        ? "background-color: var(--em-forest);"
        : $"background-image: url('{imageUrl}');";

    private void OpenBusiness(Guid businessId) => NavigationManager.NavigateTo($"/businesses/{businessId}");

    private void HandleCartChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        CartService.OnChange -= HandleCartChanged;
    }
}
