@page "/"
@using Netrom_Eco_Meal.Controllers
@rendermode InteractiveServer
@inject BusinessController BusinessController
@inject PackageController PackageController

<PageTitle>Dashboard — Eco Meal</PageTitle>

<div class="mb-4">
    <h1 class="h3 fw-bold mb-1">Dashboard</h1>
    <p class="text-muted small mb-0">Welcome to the Eco Meal Admin Panel</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3 bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-building fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Businesses</div>
                    @if (_businessCount is null)
                    {
                        <div class="spinner-border spinner-border-sm text-primary mt-1" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    }
                    else
                    {
                        <div class="fw-bold fs-4">@_businessCount</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3 bg-success bg-opacity-10 text-success">
                    <i class="bi bi-box-seam fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Packages</div>
                    @if (_packageCount is null)
                    {
                        <div class="spinner-border spinner-border-sm text-success mt-1" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    }
                    else
                    {
                        <div class="fw-bold fs-4">@_packageCount</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3 bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-cart3 fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Orders</div>
                    <div class="fw-bold fs-4 text-muted">—</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3 bg-info bg-opacity-10 text-info">
                    <i class="bi bi-people fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Users</div>
                    <div class="fw-bold fs-4 text-muted">—</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                <h6 class="fw-semibold mb-0">Quick Actions</h6>
            </div>
            <div class="card-body d-flex flex-column gap-2 px-4 pb-4">
                <a href="/businesses" class="btn btn-outline-primary d-flex align-items-center gap-2">
                    <i class="bi bi-building"></i> View All Businesses
                </a>
                <a href="/businesses/create" class="btn btn-outline-success d-flex align-items-center gap-2">
                    <i class="bi bi-plus-circle"></i> Add New Business
                </a>
                <a href="/packages" class="btn btn-outline-primary d-flex align-items-center gap-2">
                    <i class="bi bi-box-seam"></i> View All Packages
                </a>
                <a href="/packages/create" class="btn btn-outline-success d-flex align-items-center gap-2">
                    <i class="bi bi-plus-circle"></i> Add New Package
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                <h6 class="fw-semibold mb-0">About Eco Meal</h6>
            </div>
            <div class="card-body px-4 pb-4">
                <p class="text-muted small mb-0">
                    Eco Meal connects eco-conscious businesses with customers through sustainable food packages and orders.
                    Use this admin panel to manage businesses, packages, and orders across the platform.
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    private int? _businessCount;
    private int? _packageCount;

    protected override async Task OnInitializedAsync()
    {
        _businessCount = (await BusinessController.GetAllAsync()).Value?.Count;
        _packageCount = (await PackageController.GetAllAsync()).Value?.Count;
    }
}