@page "/packages/create"
@page "/packages/edit/{Id:guid}"
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Netrom_Eco_Meal.Constants
@using Netrom_Eco_Meal.Controllers
@using Netrom_Eco_Meal.Entities
@using Netrom_Eco_Meal.Services
@using Netrom_Eco_Meal.Services.Interfaces
@rendermode InteractiveServer
@implements IDisposable
@inject PackageController PackageController
@inject IPackageTypeService PackageTypeService
@inject IBusinessService BusinessService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject ClientTimeZoneService ClientTimeZoneService
@attribute [Authorize(Roles = $"{AppRoles.Admin},{AppRoles.BusinessManager}")]

<PageTitle>@(IsEdit ? "Edit Package" : "Create Package") — Eco Meal</PageTitle>

@if (_forbidden)
{
    <ForbiddenPanel Message="@_forbiddenReason" BackHref="/packages" BackLabel="Back to packages"/>
    return;
}

@if (_notFound)
{
    <NotFoundPanel Title="Package not found" Message="This package no longer exists — it may have already been deleted."
                   BackHref="/packages" BackLabel="Back to packages"/>
    return;
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">@(IsEdit ? "Edit Package" : "Create Package")</h1>
        <p class="text-muted small mb-0">@(IsEdit ? "Update the package details" : "Add a new food package to the platform")</p>
    </div>
    <a href="/packages" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <EditForm Model="@_model" OnValidSubmit="Submit" FormName="packageForm">
                    <DataAnnotationsValidator/>
                    <div class="mb-3">
                        <label for="name" class="form-label fw-semibold">Name</label>
                        <InputText id="name" class="form-control" placeholder="e.g. Morning Pastry Box" @bind-Value="_model.Name"/>
                        <ValidationMessage For="@(() => _model.Name)" class="validation-message small d-block mt-1"/>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label fw-semibold">Description</label>
                        <InputText id="description" class="form-control" placeholder="Short description of the package" @bind-Value="_model.Description"/>
                        <ValidationMessage For="@(() => _model.Description)" class="validation-message small d-block mt-1"/>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label for="business" class="form-label fw-semibold">Business</label>
                            <InputSelect id="business" class="form-select" @bind-Value="_model.BusinessId" disabled="@(!_isAdmin)">
                                @foreach (var business in _businesses)
                                {
                                    <option value="@business.Id">@business.Name</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-sm-6">
                            <label for="packageType" class="form-label fw-semibold">Type</label>
                            <InputSelect id="packageType" class="form-select" @bind-Value="_model.PackageTypeId">
                                @foreach (var type in _packageTypes)
                                {
                                    <option value="@type.Id">@type.Name</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label for="price" class="form-label fw-semibold">Price</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <InputNumber id="price" class="form-control" placeholder="0.00" @bind-Value="_model.Price"/>
                            </div>
                            <ValidationMessage For="@(() => _model.Price)" class="validation-message small d-block mt-1"/>
                        </div>
                        <div class="col-sm-6">
                            <label for="quantity" class="form-label fw-semibold">Quantity</label>
                            <InputNumber id="quantity" class="form-control" placeholder="1" @bind-Value="_model.Quantity"/>
                            <ValidationMessage For="@(() => _model.Quantity)" class="validation-message small d-block mt-1"/>
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label for="pickupStart" class="form-label fw-semibold">Pickup Start</label>
                            <InputDate id="pickupStart" class="form-control" Type="InputDateType.DateTimeLocal" @bind-Value="_model.PickupStart"/>
                        </div>
                        <div class="col-sm-6">
                            <label for="pickupEnd" class="form-label fw-semibold">Pickup End</label>
                            <InputDate id="pickupEnd" class="form-control" Type="InputDateType.DateTimeLocal" @bind-Value="_model.PickupEnd"/>
                        </div>
                        <ValidationMessage For="@(() => _model.PickupEnd)" class="validation-message small d-block mt-1"/>
                    </div>
                    <div class="mb-4">
                        <label for="imageUrl" class="form-label fw-semibold">
                            Image URL <span class="text-muted fw-normal">(optional)</span>
                        </label>
                        <InputText id="imageUrl" class="form-control" placeholder="https://..." @bind-Value="_model.ImageUrl"/>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="bi bi-check-lg me-1"></i> @(IsEdit ? "Save Changes" : "Create Package")
                    </button>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool IsEdit => Id.HasValue;

    private PackageFormModel _model = new();
    private List<PackageType> _packageTypes = [];
    private List<Business> _businesses = [];
    private bool _isAdmin;
    private bool _forbidden;
    private string _forbiddenReason = "";
    private bool _notFound;

    // Raw UTC, so the pickup fields can be re-derived if the timezone resolves late.
    private DateTime? _existingPickupStartUtc;
    private DateTime? _existingPickupEndUtc;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAdmin = authState.User.IsInRole(AppRoles.Admin);
        var currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        Business? myBusiness = null;
        if (!_isAdmin && currentUserId is not null)
            myBusiness = await BusinessService.GetByManagerIdAsync(currentUserId);

        if (!_isAdmin && myBusiness is null)
        {
            _forbidden = true;
            _forbiddenReason = "You don't manage a business yet, so you can't add or edit packages.";
            return;
        }

        _packageTypes = await PackageTypeService.GetAllAsync();
        _businesses = _isAdmin ? await BusinessService.GetAllAsync() : [myBusiness!];

        if (IsEdit)
        {
            var existing = (await PackageController.GetByIdAsync(Id!.Value)).Value;
            if (existing is null)
            {
                _notFound = true;
                return;
            }

            if (!_isAdmin && existing.BusinessId != myBusiness!.Id)
            {
                _forbidden = true;
                _forbiddenReason = "You can only edit packages that belong to your business.";
                return;
            }

            _existingPickupStartUtc = existing.PickupStart;
            _existingPickupEndUtc = existing.PickupEnd;

            _model.Name = existing.Name;
            _model.Description = existing.Description;
            _model.Price = existing.Price;
            _model.Quantity = existing.Quantity;
            _model.PickupStart = ClientTimeZoneService.ToLocal(existing.PickupStart);
            _model.PickupEnd = ClientTimeZoneService.ToLocal(existing.PickupEnd);
            _model.ImageUrl = existing.ImageUrl;
            _model.BusinessId = existing.BusinessId;
            _model.PackageTypeId = existing.PackageTypeId;
            _model.NowLocal = ClientTimeZoneService.ToLocal(DateTime.UtcNow);
        }
        else
        {
            // InputSelect only syncs its bound value once the user changes the selection, so without
            // these defaults the IDs stay Guid.Empty and the insert fails its FK constraints.
            if (_packageTypes.Count > 0)
                _model.PackageTypeId = _packageTypes[0].Id;
            if (_businesses.Count > 0)
                _model.BusinessId = _businesses[0].Id;

            var localNow = ClientTimeZoneService.ToLocal(DateTime.UtcNow);
            _model.PickupStart = localNow;
            _model.PickupEnd = localNow.AddHours(2);
            _model.NowLocal = localNow;
        }

        // Re-derives the fields above if the timezone resolves after they were first set.
        ClientTimeZoneService.OnChange += HandleTimeZoneChanged;
    }

    private void HandleTimeZoneChanged()
    {
        if (IsEdit)
        {
            if (_existingPickupStartUtc.HasValue)
                _model.PickupStart = ClientTimeZoneService.ToLocal(_existingPickupStartUtc.Value);
            if (_existingPickupEndUtc.HasValue)
                _model.PickupEnd = ClientTimeZoneService.ToLocal(_existingPickupEndUtc.Value);
            _model.NowLocal = ClientTimeZoneService.ToLocal(DateTime.UtcNow);
        }
        else
        {
            var localNow = ClientTimeZoneService.ToLocal(DateTime.UtcNow);
            _model.PickupStart = localNow;
            _model.PickupEnd = localNow.AddHours(2);
            _model.NowLocal = localNow;
        }

        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ClientTimeZoneService.OnChange -= HandleTimeZoneChanged;
    }

    private async Task Submit()
    {
        // The form works entirely in the viewer's local time — convert back to UTC for storage.
        var pickupStart = ClientTimeZoneService.ToUtc(_model.PickupStart);
        var pickupEnd = ClientTimeZoneService.ToUtc(_model.PickupEnd);

        if (IsEdit)
        {
            var package = new Package
            {
                Id = Id!.Value,
                Name = _model.Name!,
                Description = _model.Description!,
                Price = _model.Price,
                Quantity = _model.Quantity,
                PickupStart = pickupStart,
                PickupEnd = pickupEnd,
                ImageUrl = _model.ImageUrl,
                BusinessId = _model.BusinessId,
                PackageTypeId = _model.PackageTypeId
            };
            await PackageController.UpdateAsync(package);
        }
        else
        {
            var package = new Package
            {
                Name = _model.Name!,
                Description = _model.Description!,
                Price = _model.Price,
                Quantity = _model.Quantity,
                PickupStart = pickupStart,
                PickupEnd = pickupEnd,
                ImageUrl = _model.ImageUrl,
                BusinessId = _model.BusinessId,
                PackageTypeId = _model.PackageTypeId
            };
            await PackageController.AddAsync(package);
        }

        NavigationManager.NavigateTo("/packages");
    }

    private class PackageFormModel : IValidatableObject
    {
        [Required(ErrorMessage = "Enter a package name.")]
        public string? Name { get; set; }

        [Required(ErrorMessage = "Enter a short description.")]
        public string? Description { get; set; }

        [Range(0.01, 10000, ErrorMessage = "Price must be greater than 0.")]
        public decimal Price { get; set; }

        [Range(1, 1000, ErrorMessage = "Quantity must be at least 1.")]
        public int Quantity { get; set; } = 1;

        public DateTime PickupStart { get; set; } = DateTime.Now;
        public DateTime PickupEnd { get; set; } = DateTime.Now.AddHours(2);
        public string? ImageUrl { get; set; }
        public Guid BusinessId { get; set; }
        public Guid PackageTypeId { get; set; }

        // Kept in sync with the viewer's local time by the parent component — comparing PickupEnd
        // against DateTime.Now here would use the server's timezone instead of the viewer's.
        public DateTime NowLocal { get; set; } = DateTime.Now;

        // Cross-field rules — can't be expressed with a single [Range]/[Required] attribute.
        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (PickupEnd <= PickupStart)
                yield return new ValidationResult("Pickup end must be after pickup start.", [nameof(PickupEnd)]);

            // Only PickupEnd is checked so editing a package that's already mid-window (PickupStart
            // in the past, PickupEnd still ahead) doesn't get blocked.
            if (PickupEnd <= NowLocal)
                yield return new ValidationResult("Pickup end must be in the future.", [nameof(PickupEnd)]);
        }
    }
}