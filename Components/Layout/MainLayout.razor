@inherits LayoutComponentBase
@using Netrom_Eco_Meal.Services
@inject ClientTimeZoneService ClientTimeZoneService

<div class="page">
    <div class="sidebar">
        <NavMenu/>
    </div>

    <main>
        <article class="content px-4 py-4">
            @Body
        </article>
    </main>
</div>

@* Required by the framework; styled globally in app.css, not CSS-isolated. *@
<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Needs JS interop (Intl API), only available after the first render.
        if (firstRender)
        {
            await ClientTimeZoneService.InitializeAsync();
            StateHasChanged();
        }
    }
}